                        <div class="checkbox"></div>
                        <div><strong>Infraestrutura elétrica/hidráulica</strong></div>
                    </div>
                    <div class="list-item critical">
                        <div class="checkbox"></div>
                        <div><strong>Estacionamento na porta</strong></div>
                    </div>
                    <div class="list-item critical">
                        <div class="checkbox"></div>
                        <div><strong>Tamanho 300-400m²</strong></div>
                    </div>
                    <div class="list-item critical">
                        <div class="checkbox"></div>
                        <div><strong>Espaço de carga/rampa</strong></div>
                    </div>
                </div>
                <div>
                    <div class="list-item">
                        <div class="checkbox"></div>
                        <div><strong>Público Classe C/D</strong></div>
                    </div>
                    <div class="list-item">
                        <div class="checkbox"></div>
                        <div><strong>Alto fluxo pessoas/veículos</strong></div>
                    </div>
                    <div class="list-item">
                        <div class="checkbox"></div>
                        <div><strong>Comércios complementares</strong></div>
                    </div>
                    <div class="list-item">
                        <div class="checkbox"></div>
                        <div><strong>Longe de outras lojas (2-3km)</strong></div>
                    </div>
                    <div class="list-item">
                        <div class="checkbox"></div>
                        <div><strong>Perto de Supermercado BH</strong></div>
                    </div>
                </div>
            </div>

            <div class="subsection-title" style="margin-top: 30px;">Bairros Candidatos para Expansão</div>
            
            <div class="collapsible active">
                <div>✅ <strong>Confirmados (Pronto para Ação)</strong></div>
                <span class="arrow">▼</span>
