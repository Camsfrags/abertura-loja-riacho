        <!-- METODOLOGIA DE EXPANSÃO -->
        <div class="card">
            <div class="card-title">
                <span class="card-icon">🗺️</span>
                Metodologia de Expansão - Estudo de Locais
            </div>

            <div class="methodology">
                <div class="methodology-title">📍 Como Hudson & César Escolhem Locais</div>
                <div class="methodology-text">
                    A seleção estratégica de locais segue um processo de 5 etapas rigorosas: 
                    (1) Pesquisa inicial em Google Maps, (2) Busca de imóvel em imobiliárias, 
                    (3) Visita presencial de Hudson, (4) Validação de layout com César, 
                    (5) Aprovação executiva. Nunca comprar antes de TUDO estar validado.
                </div>
            </div>

            <div class="subsection-title">10 Critérios Essenciais</div>
            
            <div class="grid-2">
                <div>
                    <div class="list-item critical">
                        <div class="checkbox"></div>
                        <div><strong>Aluguel 3K-10K</strong></div>
                    </div>
